{
  "productName": "Gemia",
  "version": "0.1.0",
  "identifier": "ai.gemia.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Gemia",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:7788 http://127.0.0.1:7788; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": [],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "externalBin": [
      "binaries/gemia-server"
    ]
  }
}
