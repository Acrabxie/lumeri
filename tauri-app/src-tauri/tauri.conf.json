{
  "productName": "Gemia",
  "version": "0.1.0",
  "identifier": "ai.gemia.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Gemia",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:7788 http://127.0.0.1:7788 http://localhost:1420 ws://localhost:1420; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": [],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "externalBin": [
      "binaries/gemia-server"
    ]
  }
}
