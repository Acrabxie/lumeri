  "pending_runtime_fixes": [
    "Normalize start_frame plus duration into absolute timeline metadata and execution",
    "Stop double-applying video primitive chains in execute_layer_plan",
    "Fix shadow preview crop-versus-scale mismatch for raster layers",
    "Replace bridge false-green heartbeat with lane-aware controller heartbeat",
    "Prevent lease staleness from duplicating long-running delegated jobs"
